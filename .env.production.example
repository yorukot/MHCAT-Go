# Production identity and connections
MHCAT_ENV=production
MHCAT_DISCORD_TOKEN=<discord-bot-token>
MHCAT_REPORT_WEBHOOK_URL=<report-webhook-url>
MHCAT_MONGODB_URI=mongodb://<username>:<password>@mongodb:27017/mhcat-database?authSource=admin&replicaSet=rs0
MHCAT_MONGODB_DATABASE=mhcat-database

# Discord currently recommends 16 shards for this bot.
MHCAT_DISCORD_SHARD_COUNT=16

# Required by the production scheduler workers. Child shards receive unique suffixes.
MHCAT_SCHEDULER_LEASE_OWNER=mhcat-production

# Legacy MHCAT server welcome message
MHCAT_LEGACY_WELCOME_SPECIAL_GUILD_ID=976879837471973416
